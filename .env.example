# LicitAI — Variáveis de ambiente
# Copie este arquivo para .env e ajuste os valores.
# O .env NÃO deve ser commitado (já está no .gitignore).

# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Para rodar local sem MySQL: mantenha DB_DRIVER=sqlite
DB_DRIVER=sqlite
DB_SQLITE_PATH=

# MySQL (apenas quando DB_DRIVER=mysql)
DB_HOST=localhost
DB_NAME=licita_ia
DB_USER=root
DB_PASS=

# ─── IA / OpenRouter ─────────────────────────────────────────────────────────
# Chave real para o OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sua-chave-aqui

# Para apontar para uma API de análise local/mock:
# OPENROUTER_API_URL=http://localhost:8080/v1/chat/completions
OPENROUTER_API_URL=

# Modelo padrão — compatível com a API OpenAI
# OPENROUTER_MODEL=anthropic/claude-haiku-4-5-20251001
OPENROUTER_MODEL=

# ─── Aplicação ────────────────────────────────────────────────────────────────
# Porta do servidor embutido PHP: php -S localhost:8000 -t .
APP_URL=http://localhost:8000
APP_SECRET=troque-por-string-aleatoria-longa
CRON_SECRET=troque-por-outro-segredo-longo
